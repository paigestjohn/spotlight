{
  "name": "Spotlight sandbox",
  "build": {
    "dockerfile": "../container/Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspace",
  "remoteUser": "node",
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached"
  ],
  "containerEnv": {
    "SPOTLIGHT_SANDBOX": "devcontainer"
  },
  "postCreateCommand": "bash tests/smoke.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ]
    }
  }
}
