{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.0",
  "type": "object",
  "required": ["schema_version", "project", "investigation_plan"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "project": { "type": "string" },
    "lead": { "type": "string" },
    "planned_at": { "type": "string", "format": "date-time" },
    "brief_directions": { "type": "array", "items": { "type": "string" } },
    "skills_invoked": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Skills explicitly loaded while designing the methodology."
    },
    "navigator": {
      "type": "object",
      "required": ["required", "used"],
      "properties": {
        "required": { "type": "boolean" },
        "used": { "type": "boolean" },
        "status": { "enum": ["green", "yellow", "red", "missing", "unknown"] },
        "queries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["direction", "endpoint", "request_path", "response_path"],
            "properties": {
              "direction": { "type": "string" },
              "endpoint": { "enum": ["/api/tools/search", "/api/query"] },
              "request_path": { "type": "string" },
              "response_path": { "type": "string" },
              "selected_tools": { "type": "array", "items": { "type": "string" } },
              "rejected_tools": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "tool": { "type": "string" },
                    "reason": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "fallback_used": { "type": "boolean" },
        "fallback_reason": { "type": "string" }
      }
    },
    "rlm": {
      "type": "object",
      "description": "Per-case RLM decision made during methodology approval. RLM output is lead-only and never publishable evidence.",
      "required": ["available", "proposed", "approved", "mode", "evidence_boundary"],
      "properties": {
        "available": { "type": "boolean" },
        "proposed": { "type": "boolean" },
        "approved": { "type": "boolean" },
        "mode": { "enum": ["off", "lite", "local_gemma4_e4b"] },
        "model": { "type": ["string", "null"] },
        "prefilter": { "type": "boolean" },
        "hybrid": { "type": "boolean" },
        "decision_at": { "type": "string", "format": "date-time" },
        "decision_by": { "type": "string" },
        "run_id": { "type": "string" },
        "request_path": { "type": "string" },
        "analysis_path": { "type": "string" },
        "audit_path": { "type": "string" },
        "declined_reason": { "type": "string" },
        "skip_reason": { "type": "string" },
        "evidence_boundary": {
          "const": "lead-only; never verified or publishable"
        }
      }
    },
    "investigation_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["direction", "questions", "steps"],
        "properties": {
          "direction": { "type": "string" },
          "questions": { "type": "array", "items": { "type": "string" } },
          "navigator_not_applicable_reason": { "type": "string" },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["order", "action", "tool"],
              "properties": {
                "order": { "type": "integer" },
                "action": { "type": "string" },
                "tool": { "type": "string" },
                "target": { "type": "string" },
                "expected_evidence": { "type": "string" },
                "fallback": { "type": "string" },
                "tool_source": {
                  "enum": ["navigator", "curated-catalog", "prior-vault", "user-specified"]
                },
                "navigator_response_path": { "type": "string" }
              }
            }
          },
          "osint_techniques": { "type": "array", "items": { "type": "string" } },
          "key_sources": { "type": "array", "items": { "type": "string" } },
          "risks": { "type": "array", "items": { "type": "string" } },
          "estimated_difficulty": { "enum": ["quick scan", "moderate", "deep document trail"] }
        }
      }
    },
    "tools_required": { "type": "array", "items": { "type": "string" } },
    "opsec_considerations": { "type": "array", "items": { "type": "string" } },
    "limitations": { "type": "array", "items": { "type": "string" } }
  }
}
