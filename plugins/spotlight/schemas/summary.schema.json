{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.0",
  "type": "object",
  "required": ["schema_version", "project", "title", "date", "overview", "conclusions"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "project": { "type": "string" },
    "title": { "type": "string" },
    "date": { "type": "string", "format": "date" },
    "cycles": { "type": "integer", "minimum": 1 },
    "status": { "type": "string" },
    "overview": { "type": "string" },
    "scope": { "type": "string" },
    "conclusions": { "type": "array", "items": { "type": "string" } },
    "findings_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "claim", "confidence", "verdict"],
        "properties": {
          "id": { "type": "string" },
          "claim": { "type": "string" },
          "confidence": { "enum": ["high", "medium", "low"] },
          "verdict": { "enum": ["verified", "unverified", "disputed", "false"] },
          "source_count": { "type": "integer" }
        }
      }
    },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "methodology_summary": { "type": "string" }
  }
}
