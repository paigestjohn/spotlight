{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spotlight RLM Analysis",
  "type": "object",
  "required": ["schema_version", "project", "run_id", "mode", "provider", "model", "created_at", "artifacts"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "project": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["lite", "local_gemma4_e4b"] },
    "provider": { "enum": ["deterministic", "ollama"] },
    "model": { "type": ["string", "null"] },
    "created_at": { "type": "string", "minLength": 1 },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "text", "source_refs", "verification_status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["entity", "timeline_event", "contradiction", "lead", "discarded"] },
          "text": { "type": "string", "minLength": 1 },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path", "line_start", "line_end"],
              "properties": {
                "path": { "type": "string", "minLength": 1 },
                "line_start": { "type": "integer", "minimum": 1 },
                "line_end": { "type": "integer", "minimum": 1 }
              },
              "additionalProperties": true
            }
          },
          "verification_status": { "const": "needs_verification" },
          "metadata": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "metrics": { "type": "object" }
  },
  "additionalProperties": true
}
