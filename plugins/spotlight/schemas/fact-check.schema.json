{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.0",
  "type": "object",
  "required": ["project"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "project": { "type": "string" },
    "source_document": { "type": "string" },
    "checked_at": { "type": "string" },
    "cycle": { "type": "integer", "minimum": 1 },
    "summary": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "total_claims": { "type": "integer" },
            "verified": { "type": "integer" },
            "partially_verified": { "type": "integer" },
            "unverified": { "type": "integer" },
            "disputed": { "type": "integer" },
            "false": { "type": "integer" },
            "mischaracterized": { "type": "integer" }
          }
        },
        { "type": "string" }
      ]
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_text", "verdict"],
        "properties": {
          "id": { "type": ["integer", "string"] },
          "finding_id": { "type": "string" },
          "claim_text": { "type": "string" },
          "verdict": { "enum": ["verified","partially_verified","unverified","disputed","false","mischaracterized"] },
          "confidence": { "enum": ["high","medium","low"] },
          "grounding_assessment": { "$ref": "#/definitions/grounding_assessment" },
          "evidence_for": { "type": "array", "items": { "$ref": "#/definitions/evidence_item" } },
          "evidence_against": { "type": "array", "items": { "$ref": "#/definitions/evidence_item" } },
          "sources": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        }
      }
    },
    "verdicts": { "type": "array" },
    "gaps_for_next_cycle": { "type": "array", "items": { "type": "string" } }
  },
  "definitions": {
    "grounding_assessment": {
      "type": "object",
      "required": [
        "support_type",
        "claim_elements_checked",
        "missing_assumptions",
        "confidence_cap",
        "assessment"
      ],
      "properties": {
        "support_type": { "enum": ["direct","indirect","inferred","contradicted","insufficient"] },
        "claim_elements_checked": { "type": "array", "items": { "type": "string" } },
        "missing_assumptions": { "type": "array", "items": { "type": "string" } },
        "confidence_cap": { "enum": ["high","medium","low"] },
        "assessment": { "type": "string" }
      }
    },
    "evidence_item": {
      "type": "object",
      "required": ["description", "source"],
      "properties": {
        "description": { "type": "string" },
        "source": { "type": "string" },
        "source_type": { "enum": ["primary","secondary"] },
        "archive_url": { "type": ["string", "null"] },
        "access_method": { "enum": ["full_text","open_access","archive_copy","abstract_only","inaccessible"] },
        "local_file": { "type": ["string", "null"] }
      }
    }
  }
}
