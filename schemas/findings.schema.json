{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.0",
  "type": "object",
  "required": ["schema_version", "project", "lead", "findings"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "project": { "type": "string" },
    "lead": { "type": "string" },
    "investigated_at": { "type": "string", "format": "date-time" },
    "cycle": { "type": "integer", "minimum": 1 },
    "questions": { "type": "array", "items": { "type": "string" } },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "claim", "evidence", "sources", "confidence", "grounding"],
        "properties": {
          "id": { "type": "string" },
          "claim": { "type": "string" },
          "evidence": { "type": "string" },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["url", "accessed", "archive_url", "access_method", "local_file"],
              "properties": {
                "url": { "type": "string", "format": "uri" },
                "type": { "enum": ["court_filing","news","registry","social_media","government","ngo_report","satellite","other"] },
                "accessed": { "type": "string", "format": "date-time" },
                "archive_url": { "type": "string" },
                "local_file": { "type": "string" },
                "access_method": { "enum": ["full_text","open_access","archive_copy","abstract_only","inaccessible"] }
              }
            }
          },
          "confidence": { "enum": ["high","medium","low"] },
          "confidence_rationale": { "type": "string" },
          "grounding": { "$ref": "#/definitions/grounding" },
          "evidence_bundle_refs": { "type": "array", "items": { "type": "string" } },
          "perspective": { "enum": ["official","affected_community","independent_observer","corporate","legal"] }
        }
      }
    },
    "connections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "relationship"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "relationship": { "type": "string" },
          "evidence": { "type": "string" }
        }
      }
    },
    "gaps": { "type": "array", "items": { "type": "string" } },
    "next_steps": { "type": "array", "items": { "type": "string" } },
    "monitoring_recommendations": {
      "type": "array",
      "items": { "$ref": "#/definitions/monitoring_recommendation" }
    }
  },
  "definitions": {
    "grounding": {
      "type": "object",
      "required": [
        "support_type",
        "grounding_strength",
        "source_role",
        "quote_match",
        "claim_elements_supported",
        "missing_assumptions",
        "contradictions",
        "confidence_cap",
        "misgrounding_risk",
        "grounding_rationale"
      ],
      "properties": {
        "support_type": { "enum": ["direct","indirect","inferred","contradicted","insufficient"] },
        "grounding_strength": { "enum": ["full","partial","weak","none"] },
        "source_role": { "enum": ["primary","secondary","contextual"] },
        "quote_match": { "enum": ["exact","paraphrase","contextual","none"] },
        "claim_elements_supported": { "type": "array", "items": { "type": "string" } },
        "missing_assumptions": { "type": "array", "items": { "type": "string" } },
        "contradictions": { "type": "array", "items": { "type": "string" } },
        "confidence_cap": { "enum": ["high","medium","low"] },
        "misgrounding_risk": { "type": "string" },
        "grounding_rationale": { "type": "string" }
      }
    },
    "monitoring_recommendation": {
      "type": "object",
      "required": ["id", "target", "scout_type", "criteria", "rationale", "priority"],
      "properties": {
        "id": { "type": "string" },
        "target": { "type": "string" },
        "scout_type": { "enum": ["web","pulse","social","civic"] },
        "criteria": { "type": "string" },
        "rationale": { "type": "string" },
        "priority": { "enum": ["high","medium","low"] },
        "finding_refs": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
